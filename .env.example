# Infrastructure (Vapi handles the Voice/Telecom)
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_PUBLIC_KEY=your_vapi_public_key

# Database (Qdrant handles the Memory - Free Tier)
QDRANT_URL=your_qdrant_cluster_url
QDRANT_API_KEY=your_qdrant_api_key

# Brain (Groq handles Llama 3.1 - Free Tier)
GROQ_API_KEY=your_groq_api_key

# Configuration
PORT=8000
DATABASE_COLLECTION=accessibility_knowledge
